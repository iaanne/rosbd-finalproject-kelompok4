# Cassandra
CASSANDRA_HOST=localhost

# Elasticsearch
ELASTICSEARCH_HOST=http://localhost:9200

# SMTP Email Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Sender & Recipients
SMTP_FROM=alert@dedolarisasi.com
ALERT_EMAIL_BI=bi@example.com
ALERT_EMAIL_INVESTOR=investor@example.com

# IDR Volatility Threshold (fractional — default 0.005 = 0.5%)
IDR_VOLATILITY_THRESHOLD=0.005
